{
  "manifest_version": 3,
  "name": "Restore 100 Search Results",
  "version": "1.0",
  "host_permissions": [
    "https://www.google.com/search*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}